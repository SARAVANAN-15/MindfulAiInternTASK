//Async & await Insted of Promises

function checkSeat() {
    return new Promise((resolve, reject) => {
        let seatAvailable = true;

        if (seatAvailable) {
            console.log("Seat available");
            resolve();
        } else {
            reject("Seat not available");
        }
    });
}
function payment() {
    return new Promise((resolve, reject) => {
        let paymentSuccess = true;

        if (paymentSuccess) {
            console.log("Payment successful");
            resolve();
        } else {
            reject("Payment failed");
        }
    });
}

function ticketConfirm() {
    return new Promise((resolve) => {
        console.log("Ticket booked successfully");
        resolve();
    });
}

async function bookTicket() {
    try {
        await checkSeat();
        await payment();
        await ticketConfirm();
    }
    catch(error) {
        console.log(error);
    }
}

bookTicket();
